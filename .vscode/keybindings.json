[
  {
    "key": "ctrl+alt+shift+n ctrl+alt+shift+f",
    "command": "workbench.action.tasks.runTask",
    "args": "Normi Autofix: Active File",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "ctrl+alt+shift+n ctrl+alt+shift+c",
    "command": "workbench.action.tasks.runTask",
    "args": "Normi Check: Active File",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+alt+shift+n ctrl+alt+shift+a",
    "command": "workbench.action.tasks.runTask",
    "args": "Normi Check: ft_printf All",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+alt+shift+n ctrl+alt+shift+p",
    "command": "workbench.action.tasks.runTask",
    "args": "Normi Check: Project All",
    "when": "editorTextFocus"
  }
]
